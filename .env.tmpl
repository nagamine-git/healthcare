GARMIN_PASSWORD="op://Personal/l3zw5muzhwqz3fkcsqsbjrqz5a/password"

# --- Health Auto Export Bearer token ---
HAE_INGEST_TOKEN="op://Personal/3jtudssyhgh3kajjjvq7ek3v6y/password"

