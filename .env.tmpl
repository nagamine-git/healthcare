# 1Password CLI で値を解決して docker compose に渡すためのテンプレ。
# 実コマンド: op run --env-file=.env.tmpl -- docker compose up -d
#
# 参照は UUID 直指定 (アイテムをリネームしても壊れない)。
# 解決される 1Password アイテム:
#   anthropic key            (Personal, coa3nmxh...) → password
#   Garmin                   (Personal, l3zw5muz...) → username + password
#   TailScaleAuthKey         (Personal, d6k2tduo...) → password
#   HealthAutoExport Bearer  (Personal, 3jtudssy...) → password
#
# 検証:  op run --env-file=.env.tmpl -- env | grep -E '^(ANTHROPIC|GARMIN|HAE_|TS_AUTHKEY)='

# --- Anthropic ---
ANTHROPIC_API_KEY="op://Personal/coa3nmxhuv2fnx5uxkbq2my5za/password"
LLM_MODEL=claude-sonnet-4-6

# --- Garmin ---
GARMIN_EMAIL="op://Personal/l3zw5muzhwqz3fkcsqsbjrqz5a/username"
GARMIN_PASSWORD="op://Personal/l3zw5muzhwqz3fkcsqsbjrqz5a/password"

# --- Health Auto Export Bearer token ---
HAE_INGEST_TOKEN="op://Personal/3jtudssyhgh3kajjjvq7ek3v6y/password"

# --- Tailscale ---
TS_AUTHKEY="op://Personal/d6k2tduofdlgzkxbj66a4kg72m/password"
TS_HOSTNAME=healthcare
TS_EXTRA_ARGS=--ssh

# --- App ---
APP_TZ=Asia/Tokyo
APP_DATA_DIR=/data
APP_LOG_LEVEL=INFO
