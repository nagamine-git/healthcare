# Copy to .env and fill in. (1Password users: see .env.tmpl for an `op run` template.)

# --- Anthropic (LLM coaching) ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# --- Garmin Connect ---
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password

# --- Health Auto Export (iPhone -> /ingest). Any random secret string. ---
HAE_INGEST_TOKEN=change-me-to-a-long-random-string

# --- Tailscale (private access). Generate an auth key with tag:healthcare. ---
TS_AUTHKEY=tskey-auth-...
TS_HOSTNAME=healthcare
TS_EXTRA_ARGS=--ssh

# --- App ---
APP_TZ=Asia/Tokyo
APP_DATA_DIR=/data
APP_LOG_LEVEL=INFO

# --- Web Push 通知 (VAPID) ---
# 鍵ペアの生成: cd backend && .venv/bin/python -m app.cli_vapid
# private は秘密、public はブラウザに配る applicationServerKey。
# 未設定なら通知は無効 (購読・送信ともスキップ)。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Personal profile (overrides the example profile in config.py) ---
USER_AGE=30
USER_SEX=male
USER_HEIGHT_CM=170
USER_RESTING_HR=60
TARGET_WEIGHT_KG=65
TARGET_BODY_FAT_PCT=18
# Barometric migraine monitoring — set to your location
WEATHER_LATITUDE=35.6812
WEATHER_LONGITUDE=139.7671
WEATHER_LOCATION_LABEL=Tokyo
